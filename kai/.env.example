# Server-side only. NEVER prefix with VITE_ — Vite would bundle it
# into the client. Set these in Vercel: Project → Settings →
# Environment Variables.

# Anthropic Messages API key — read by /api/claude
ANTHROPIC_API_KEY=sk-ant-...

# Google Calendar secret iCal URL — read by /api/calendar
# Get it from Google Calendar → Settings → Settings for my calendars →
# Integrate calendar → "Secret address in iCal format".
# Keep this private — anyone with the URL can read your calendar.
GOOGLE_CALENDAR_ICAL_URL=https://calendar.google.com/calendar/ical/.../private-.../basic.ics
